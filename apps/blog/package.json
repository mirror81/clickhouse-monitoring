{
  "name": "blog",
  "description": "chmonitor blog (blog.chmonitor.dev) — release notes and product updates",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/sync-shared-assets.mjs && astro dev",
    "build": "node ../../scripts/sync-shared-assets.mjs && astro build",
    "preview": "astro preview",
    "build:og": "bun run scripts/build-og.ts",
    "release-to-post": "bun run scripts/release-to-post.mjs",
    "test": "bun test src/lib",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.3.0",
    "astro": "^7.0.0",
    "posthog-js": "^1.396.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "sharp": "^0.34.0",
    "wrangler": "^4.97.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
