{
  "name": "cloud-hooks",
  "description": "Cloudflare Worker for chmonitor Cloud (SaaS): receives Polar billing webhooks, persists subscriptions to the shared D1, and sends operator notifications (Telegram) + scheduled ops jobs (daily billing summary, health probes).",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy --minify",
    "deploy:preview": "wrangler deploy --minify --env preview",
    "dev": "wrangler dev",
    "test": "bun test src/ --isolate",
    "type-check": "tsc --noEmit",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "@chm/billing-webhook-core": "workspace:*",
    "@chm/pricing": "workspace:*",
    "@polar-sh/sdk": "^0.48.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260603.1",
    "typescript": "^6.0.0",
    "wrangler": "^4.97.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
