{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@chm/billing-webhook-core": [
        "../../packages/billing-webhook-core/src/index.ts"
