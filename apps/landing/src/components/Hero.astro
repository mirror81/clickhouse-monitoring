---
import HeroHalftone from './HeroHalftone.tsx'
import { formatCount, getGitHubStats } from '../lib/github-stars'

// Build-time star count for the hero GitHub badge, shared with SocialProof so
// the build makes one API call. Empty string when the fetch fails — the badge
// then renders as a plain "Star on GitHub" with no fabricated number.
const { stars } = await getGitHubStats()
const starLabel = formatCount(stars)

// Leads with the advisor/agent + alerts + topology + insights wedge (plan 60);
// the rest keep their prior relative order.
const galleryCards = [
  { tab: 'AI Agent', src: '/landing-assets/hero-agent.png', alt: 'chmonitor AI agent' },
  { tab: 'Alerts', src: '/landing-assets/hero-health.png', alt: 'chmonitor health summary and alert thresholds' },
  { tab: 'Cluster Topology', src: '/landing-assets/hero-topology.png', alt: 'chmonitor cluster topology' },
  { tab: 'Cluster Insights', src: '/landing-assets/g-insights.png', alt: 'chmonitor cluster insights' },
  { tab: 'Overview', src: '/landing-assets/hero-overview.png', alt: 'chmonitor cluster overview' },
  { tab: 'Running Queries', src: '/landing-assets/g-running.png', alt: 'chmonitor running queries' },
  { tab: 'Explain Query', src: '/landing-assets/g-explain.png', alt: 'chmonitor explain query' },
  { tab: 'Most Expensive Queries', src: '/landing-assets/g-expensive.png', alt: 'chmonitor most expensive queries' },
  { tab: 'Data Explorer', src: '/landing-assets/g-data-explorer.png', alt: 'chmonitor data explorer' },
  { tab: 'Metrics', src: '/landing-assets/g-metrics.png', alt: 'chmonitor metrics' },
]
---
<section class="ehero">
  <div class="ehero-card">
    <div class="ehero-shader"><HeroHalftone client:idle={{ timeout: 300 }} /></div>
    <div class="ehero-scrim" aria-hidden="true"></div>

    <span class="ehero-status">
      <span class="dot"></span> Live cluster telemetry ·
      <a href="https://github.com/chmonitor/chmonitor/blob/main/LICENSE" target="_blank" rel="noopener">open source, GPL-3.0</a>
    </span>

    <div class="ehero-content">
      <span class="ehero-eyebrow">Real-time ClickHouse observability</span>
      <h1 class="ehero-title">
        <span class="l1">The <span class="ch-hl">ClickHouse advisor</span>.</span><br /><span class="accent">Now with real-time alerts.</span>
      </h1>
      <p class="ehero-sub">
        chmonitor gives you live query, merge and replication visibility from your cluster's
        <strong>system tables</strong>, an AI agent that recommends (never auto-applies) partition
        keys, skip indexes, projections and PREWHERE rewrites, and threshold alerts to any webhook
        or your Prometheus/Grafana stack. <strong>Self-host, Docker, K8s, or the hosted Cloud.</strong>
      </p>
      <div class="ehero-actions">
        <a class="btn btn-primary" href="https://dash.chmonitor.dev" target="_blank" rel="noopener" data-cta="hero-primary">
          Open dashboard
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a class="btn btn-ghost ehero-ghost" href="https://dash.chmonitor.dev" target="_blank" rel="noopener" data-cta="hero-live-demo">
          See a live demo
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        </a>
        <a class="btn btn-ghost ehero-ghost" href="https://docs.chmonitor.dev" target="_blank" rel="noopener">
          Quickstart
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/></svg>
        </a>
        <a
          class="btn btn-ghost ehero-ghost ehero-star"
          href="https://github.com/chmonitor/chmonitor"
          target="_blank"
          rel="noopener"
          data-cta="github-star-hero"
          aria-label={starLabel ? `Star chmonitor on GitHub — ${starLabel} stars` : 'Star chmonitor on GitHub'}
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 18.6 6.1 21.3l1.2-6.6L2.5 9.5l6.6-.9z"/></svg>
          Star
          {starLabel && <span class="ehero-star-count">{starLabel}</span>}
        </a>
      </div>
    </div>
  </div>

  <div class="gallery-strip reveal">
    <div class="marquee">
      {galleryCards.map((card, i) => (
        <div class="gcard">
          <div class="browser-bar"><span class="lights"><i></i><i></i><i></i></span><span class="gtab">{card.tab}</span></div>
          {/* Only the first card is a plausible above-the-fold/LCP candidate;
              the rest scroll in via the auto-scrolling marquee, so native lazy
              loading has ample lead time before they're ever visible. */}
          <img src={card.src} alt={card.alt} width="600" height="360" loading={i === 0 ? 'eager' : 'lazy'} decoding={i === 0 ? 'sync' : 'async'} />
        </div>
      ))}
      {galleryCards.map((card) => (
        <div class="gcard" aria-hidden="true">
          <div class="browser-bar"><span class="lights"><i></i><i></i><i></i></span><span class="gtab">{card.tab}</span></div>
          <img src={card.src} alt="" width="600" height="360" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Vertical rhythm only — horizontal inset lives on the card so the gallery
     strip below can span the full browser width. */
  .ehero { padding: 84px 0 100px; margin-bottom: 56px; }
  /* Card sits at ~70% width (15% gutters each side); widens as viewport narrows. */
  .ehero-card { margin: 0 15%; }
  @media (max-width: 1200px) { .ehero { padding: 56px 0 80px; } .ehero-card { margin: 0 8%; } }
  @media (max-width: 820px)  { .ehero { padding: 32px 0 60px; } .ehero-card { margin: 0 4%; } }
  @media (max-width: 640px)  { .ehero { padding: 16px 0 44px; } .ehero-card { margin: 0 14px; } }

  /* Rounded dark hero card carrying the halftone shader + editorial copy. */
  .ehero-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #0b0b0e;
    min-height: min(600px, 70vh);
    display: flex;
    isolation: isolate;
    box-shadow: 0 30px 90px -50px rgba(0,0,0,.55);
  }
  .ehero-shader { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .ehero-shader :global(canvas) { display: block; width: 100% !important; height: 100% !important; }

  /* Readability plate: a soft centered wash so the copy stays legible over the
     busy right side of the halftone (the source image is calm-left / busy-right,
     and centered text crosses into the busy zone). */
  .ehero-scrim {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      radial-gradient(ellipse 72% 66% at 50% 50%, rgba(6,6,10,.58) 0%, rgba(6,6,10,.28) 48%, rgba(6,6,10,0) 76%),
      linear-gradient(180deg, rgba(6,6,10,.35) 0%, rgba(6,6,10,0) 26%, rgba(6,6,10,0) 60%, rgba(6,6,10,.42) 100%);
  }

  .ehero-status {
    position: absolute; top: 22px; left: 22px; z-index: 3;
    display: inline-flex; align-items: center; gap: 7px;
    height: 32px; padding: 0 14px; border-radius: 999px;
    background: rgba(10,10,14,.5); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.12);
    color: #e7e7ea; font-size: 13px; font-weight: 500; white-space: nowrap;
  }
  .ehero-status a { color: #fff; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.3); }
  .ehero-status a:hover { border-color: #fff; }
  .ehero-status .dot {
    width: 7px; height: 7px; border-radius: 50%; background: #34d399;
    box-shadow: 0 0 0 3px rgba(52,211,153,.2); animation: ehero-pulse 2.4s ease-in-out infinite;
  }
  @keyframes ehero-pulse { 0%,100% { opacity: 1 } 50% { opacity: .45 } }

  .ehero-content {
    position: relative; z-index: 2; margin: auto;
    width: 100%; max-width: 880px; padding: 88px 28px;
    text-align: center;
  }
  .ehero-eyebrow {
    color: rgba(255,255,255,.66); font-size: 12.5px; font-weight: 600;
    letter-spacing: .2em; text-transform: uppercase; display: block; margin-bottom: 22px;
  }
  .ehero-title {
    font-family: var(--serif);
    color: #fff; font-weight: 600;
    font-size: clamp(2rem, 4.6vw, 3.9rem); line-height: 1.08; letter-spacing: -0.015em;
    max-width: 24ch; margin: 0 auto; text-wrap: pretty;
    text-shadow: 0 2px 40px rgba(0,0,0,.4);
  }
  /* Keep the statement on one line (line 2 is the italic accent) on desktop;
     allow it to wrap on small screens so it never overflows the card. */
  .ehero-title .l1 { white-space: nowrap; }
  @media (max-width: 720px) { .ehero-title .l1 { white-space: normal; } }
  .ehero-title .accent { font-style: italic; font-weight: 500; color: #f97316; }
  /* "ClickHouse" in the same accent orange as "As it runs." */
  .ehero-title .ch-hl { color: #f97316; }
  .ehero-sub {
    margin: 26px auto 0; max-width: 58ch;
    color: rgba(230,232,238,.9); font-size: clamp(1rem, 1.4vw, 1.22rem); line-height: 1.55; text-wrap: pretty;
  }
  .ehero-sub strong { color: #fff; font-weight: 600; }
  .ehero-actions { margin-top: 34px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  /* Ghost buttons: light-on-dark by default (dark card). The global .btn-primary
     already flips correctly per theme (light card ⇒ dark button, dark card ⇒
     light button), so it needs no override. */
  /* Solid, blurred glass so the label stays readable over the busy halftone. */
  .ehero-ghost {
    background: rgba(18,18,24,.55); color: #fff;
    border: 1px solid rgba(255,255,255,.2); backdrop-filter: blur(10px);
  }
  .ehero-ghost:hover { background: rgba(18,18,24,.72); }
  /* Star badge: the count sits behind a hairline divider with a reserved
     min-width so a present vs. absent count never shifts the button width. */
  .ehero-star { gap: 8px; }
  .ehero-star-count {
    min-width: 2.5ch; text-align: center;
    padding-left: 8px; margin-left: 1px;
    border-left: 1px solid rgba(255,255,255,.22);
    font-weight: 600; font-variant-numeric: tabular-nums;
  }
  :global(html[data-theme='light']) .ehero-star-count { border-left-color: rgba(0,0,0,.14); }

  .ehero .gallery-strip { position: relative; z-index: 1; margin-top: 64px; }

  /* ---- Light-mode hero: light paper card, dark copy, whitening scrim. ---- */
  :global(html[data-theme='light']) .ehero-card { background: #eceef2; }
  :global(html[data-theme='light']) .ehero-scrim {
    background:
      radial-gradient(ellipse 72% 68% at 50% 50%, rgba(247,248,250,.72) 0%, rgba(247,248,250,.38) 48%, rgba(247,248,250,0) 76%),
      linear-gradient(180deg, rgba(247,248,250,.4) 0%, rgba(247,248,250,0) 26%, rgba(247,248,250,0) 60%, rgba(247,248,250,.45) 100%);
  }
  :global(html[data-theme='light']) .ehero-title { color: #0b0b0e; text-shadow: none; }
  :global(html[data-theme='light']) .ehero-eyebrow { color: rgba(20,20,26,.6); }
  :global(html[data-theme='light']) .ehero-sub { color: rgba(30,30,38,.86); }
  :global(html[data-theme='light']) .ehero-sub strong { color: #0b0b0e; }
  :global(html[data-theme='light']) .ehero-status {
    background: rgba(255,255,255,.6); border-color: rgba(0,0,0,.1); color: #1e1e24;
  }
  :global(html[data-theme='light']) .ehero-status a { color: #0b0b0e; border-bottom-color: rgba(0,0,0,.28); }
  :global(html[data-theme='light']) .ehero-ghost {
    background: rgba(255,255,255,.72); color: #14141a; border-color: rgba(0,0,0,.12);
  }
  :global(html[data-theme='light']) .ehero-ghost:hover { background: rgba(255,255,255,.9); }

  @media (max-width: 640px) {
    .ehero-content { padding: 92px 22px; }
    .ehero-status { font-size: 12px; }
  }
</style>
