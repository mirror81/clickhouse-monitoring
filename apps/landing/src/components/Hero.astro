---
import { formatCount, getGitHubStats } from '../lib/github-stars'
import HeroIsland from './HeroIsland.tsx'

// Build-time star count for the hero GitHub badge/button. Empty string when the
// fetch fails — the button then renders without a fabricated number.
const { stars } = await getGitHubStats()
const starLabel = formatCount(stars)
---

<HeroIsland client:load starLabel={starLabel} />
