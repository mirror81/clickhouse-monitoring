<body>
  <slot />
  <dialog id="screenshot-zoom-dialog" class="screenshot-zoom-dialog" aria-label="Full size screenshot">
    <form method="dialog">
      <button type="submit" class="screenshot-zoom-close" aria-label="Close">×</button>
    </form>
    <div class="screenshot-zoom-body"></div>
  </dialog>
  <script is:inline>
    document.documentElement.classList.add('js');
    // Fault-isolated widget init: a throw in any one widget must never abort
    // the rest of this script — the reveal observer relied on the whole script
    // running, so a single widget failure left the lower page blank. Any
    // failure is logged, not fatal.
    function safe(fn){ try { fn(); } catch (e) { if (window.console) console.error('[landing] widget init failed:', e); } }
    // logo: fall back to the bar mark if the remote SVG can't load (e.g. offline preview)
    (function(){
      var bar = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M2 2v12M5 2v12M8 4v8M11 2v12M14 5v6"/></svg>';
      document.querySelectorAll('.mark img').forEach(function(img){
        var done = false;
        function fallback(){ if(done) return; done = true; var m = img.parentNode; if(m){ m.classList.add('mark--fallback'); m.innerHTML = bar; } }
        function ok(){ done = true; }
        img.addEventListener('error', fallback);
        img.addEventListener('load', function(){ if(img.naturalWidth > 0) ok(); else fallback(); });
        if(img.complete){ (img.naturalWidth > 0) ? ok() : fallback(); }
        // safety net: if it neither loads nor errors (blocked/hung), fall back
        setTimeout(function(){ if(!done && img.naturalWidth === 0) fallback(); }, 1600);
      });
    })();
    // draggable carousels (hero + features)
    safe(function(){
      var reduce = window.matchMedia && matchMedia('(prefers-reduced-motion:reduce)').matches;
      [].forEach.call(document.querySelectorAll('.carousel'), function(car){
        var track = car.querySelector('.ctrack');
        var slides = [].slice.call(car.querySelectorAll('.cslide'));
        if(!track || slides.length < 2) return;
        var dotsWrap = car.querySelector('.cdots');
        var paths = (car.getAttribute('data-paths')||'').split(',').filter(Boolean);
        var urlEl = car.getAttribute('data-url') ? document.getElementById(car.getAttribute('data-url')) : null;
        var autoplay = parseInt(car.getAttribute('data-autoplay')||'0', 10);
        var i = 0, timer = null, dots = [];

        if(dotsWrap){
          slides.forEach(function(_, n){
            var b = document.createElement('button');
            b.type = 'button';
            b.setAttribute('aria-label', 'Go to slide ' + (n+1));
            b.addEventListener('click', function(){ go(n); restart(); });
            dotsWrap.appendChild(b);
          });
          dots = [].slice.call(dotsWrap.children);
        }

        function render(animate){
          track.classList.toggle('no-anim', !animate);
          track.style.transform = 'translateX(' + (-i * 100) + '%)';
          dots.forEach(function(d, k){ d.setAttribute('data-on', k === i ? 'true':'false'); });
          if(urlEl && paths[i]) urlEl.textContent = paths[i];
        }
        function go(n, animate){ i = (n + slides.length) % slides.length; render(animate !== false); }
        function next(){ go(i + 1); }
        function start(){ if(autoplay && !reduce){ timer = setInterval(next, autoplay); } }
        function stop(){ if(timer){ clearInterval(timer); timer = null; } }
        function restart(){ stop(); start(); }

        // pointer drag
        var down = false, startX = 0, dx = 0, w = 1;
        function onDown(e){
          down = true; dx = 0; w = car.clientWidth || 1;
          startX = (e.touches ? e.touches[0].clientX : e.clientX);
          stop(); track.classList.add('no-anim'); car.classList.add('dragging');
        }
        function onMove(e){
          if(!down) return;
          var x = (e.touches ? e.touches[0].clientX : e.clientX);
          dx = x - startX;
          track.style.transform = 'translateX(' + (-i * 100 + (dx / w) * 100) + '%)';
        }
        function onUp(){
          if(!down) return;
          down = false; car.classList.remove('dragging');
          var threshold = w * 0.18;
          if(dx <= -threshold) go(i + 1);
          else if(dx >= threshold) go(i - 1);
          else render(true);
          restart();
        }
        car.addEventListener('mousedown', onDown);
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
        car.addEventListener('touchstart', onDown, {passive:true});
        car.addEventListener('touchmove', onMove, {passive:true});
        car.addEventListener('touchend', onUp);
        car.addEventListener('dragstart', function(e){ e.preventDefault(); });
        car.addEventListener('mouseenter', stop);
        car.addEventListener('mouseleave', function(){ if(!down) start(); });

        render(false);
        start();
      });
    })();
    // screenshot zoom (native <dialog>, no React)
    (function(){
      var dlg = document.getElementById('screenshot-zoom-dialog');
      if(!dlg) return;
      var body = dlg.querySelector('.screenshot-zoom-body');
      if(!body) return;
      function open(btn){
        var src = btn.getAttribute('data-zoom-src');
        var srcDark = btn.getAttribute('data-zoom-src-dark');
        var alt = btn.getAttribute('data-zoom-alt') || '';
        if(!src) return;
        var theme = document.documentElement.getAttribute('data-theme');
        var wanted = theme === 'dark' && srcDark ? srcDark : src;
        body.innerHTML = '';
        var img = document.createElement('img');
        img.src = wanted; img.alt = alt;
        body.appendChild(img);
        if(typeof dlg.showModal === 'function') dlg.showModal();
      }
      document.addEventListener('click', function(e){
        var btn = e.target && e.target.closest ? e.target.closest('[data-screenshot-zoom]') : null;
        if(btn) open(btn);
      });
      dlg.addEventListener('click', function(e){
        dlg.close();
      });
    })();
    // resolve theme-aware screenshot <img> src now that the DOM is parsed
    safe(function(){ if (typeof window.chmSyncThemedImages === 'function') window.chmSyncThemedImages() });
  </script>
  <!-- Reveal-on-scroll runs in its OWN script so a failure in any
       above widget can never leave the page blank (the lower sections
       are .reveal → opacity:0 until this observer adds .in). -->
  <script is:inline>
    // Reveal on scroll — independent + fail-safe.
    (function () {
      var els = document.querySelectorAll('.reveal');
      // No JS at all (script disabled) or no IntersectionObserver:
      // show everything immediately rather than leaving a blank page.
      if (!('IntersectionObserver' in window)) {
        els.forEach(function (e) { e.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach(function (e) { io.observe(e); });
    })();
  </script>
  <script>
    (function(){
      var root = document.getElementById('deployTabs');
      var section = document.getElementById('open-source');
      if(!root || !section) return;
      var tabs = [].slice.call(root.querySelectorAll('.deploy-tab'));
      var panes = [].slice.call(section.querySelectorAll('.deploy-pane'));
      function select(name){
        tabs.forEach(function(t){ t.setAttribute('data-on', t.getAttribute('data-tab') === name ? 'true':'false'); });
        panes.forEach(function(p){ p.setAttribute('data-on', p.getAttribute('data-pane') === name ? 'true':'false'); });
      }
      tabs.forEach(function(t){ t.addEventListener('click', function(){ select(t.getAttribute('data-tab')); }); });
      // per-terminal copy: read its own command lines (strip "$ " prompts, drop output)
      section.querySelectorAll('.terminal .copy').forEach(function(btn){
        btn.addEventListener('click', function(){
          var term = btn.closest('.terminal');
          var body = term && term.querySelector('.term-body');
          if(!body || !navigator.clipboard) return;
          var lines = [].slice.call(body.children).map(function(d){ return d.innerText; })
            .filter(function(l){ return l.indexOf('▸') === -1; })
            .map(function(l){ return l.replace(/^\s*\$\s/, ''); });
          var text = lines.join('\n').replace(/\n{3,}/g, '\n\n').trim();
          navigator.clipboard.writeText(text).then(function(){
            var t = btn.textContent; btn.textContent = 'Copied'; setTimeout(function(){ btn.textContent = t; }, 1400);
          });
        });
      });
    })();
  </script>
  <script>
    // Opt-in, off-by-default product analytics (PostHog) — see
    // ../lib/analytics.ts for the full privacy contract. A no-op without
    // PUBLIC_ANALYTICS_KEY, so this never runs for anyone who hasn't
    // configured it.
    import { initAnalytics, trackCtaClick, trackEvent } from '../lib/analytics'

    initAnalytics().then(function () {
      // Normalize a trailing slash — static-asset serving may resolve
      // /pricing as /pricing/ depending on host configuration.
      var path = location.pathname.replace(/\/+$/, '') || '/'
      if (path === '/') trackEvent('landing_view')
      else if (path === '/pricing') trackEvent('pricing_view')
    })

    // Delegated CTA tracking: add data-cta="<short-id>" to any link/button to
    // have its click tracked automatically.
    document.addEventListener('click', function (e) {
      var target = e.target
      var el =
        target && target.closest ? target.closest('[data-cta]') : null
      var cta = el ? el.getAttribute('data-cta') : null
      if (cta) trackCtaClick(cta)
    })
  </script>
</body>
</html>
