---
// Detailed per-feature landing pages (/features/<slug>). Content lives in
// src/data/feature-pages.ts — one rich entry per feature; this template gives
// every page the same structure: hero + zoomable hero shot, stat strip,
// numbered alternating deep-dive sections, screenshot gallery, capability
// grid, FAQ, related features and the standard closing CTA.
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import FinalCta from '../../components/FinalCta.astro'
import ScreenshotShot from '../../components/ScreenshotShot.astro'
import { FEATURE_PAGES, getFeaturePage } from '../../data/feature-pages'
import { btnOutline, btnPrimary } from '../../lib/button-classes'

export function getStaticPaths() {
  return FEATURE_PAGES.map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const page = getFeaturePage(slug!)
if (!page) throw new Error(`feature-pages.ts: missing "${slug}" entry`)

const {
  title,
  description,
  eyebrow,
  h1,
  subhead,
  hero,
  stats,
  sections,
  gallery,
  capabilities,
  faq,
  docsHref,
  related,
} = page

const relatedPages = related
  .map((r) => getFeaturePage(r))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))

const canonical = new URL(Astro.url.pathname, Astro.site).toString()

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Features', item: new URL('/#features', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: eyebrow, item: canonical },
  ],
}

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}
---
<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />
  <Nav />
  <main id="top">
    <!-- hero -->
    <section class="band fp-hero">
      <div class="wrap">
        <div class="sec-head reveal" style="text-align:center;max-width:760px;margin-inline:auto">
          <span class="eyebrow">{eyebrow}</span>
          <h1 class="fp-h1">{h1}</h1>
          <p>{subhead}</p>
        </div>
        <div class="hero-actions reveal">
          <a class={btnPrimary} href="https://dash.chmonitor.dev" target="_blank" rel="noopener" data-cta={`feature-${slug}-primary`}>
            Open dashboard
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          {docsHref && (
            <a class={btnOutline} href={docsHref} target="_blank" rel="noopener">Read the docs</a>
          )}
        </div>
        <div class="fp-hero-shot reveal">
          <div class="browser-bar"><span class="lights"><i></i><i></i><i></i></span></div>
          <ScreenshotShot id={`fp-${slug}-hero`} src={hero.src} srcDark={hero.srcDark} alt={hero.alt} eager />
        </div>
      </div>
    </section>

    <!-- stat strip -->
    <section class="band band-soft fp-stats-band">
      <div class="wrap">
        <div class="fp-stats reveal">
          {stats.map((s) => (
            <div class="fp-stat">
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- numbered deep-dive sections -->
    {sections.map((section, i) => (
      <section class={`band${i % 2 === 1 ? ' band-soft' : ''}`}>
        <div class="wrap">
          <div class={`fp-section${section.reverse ? ' fp-reverse' : ''}`}>
            <div class="fp-copy reveal">
              <span class="eyebrow">{String(i + 1).padStart(2, '0')} · {section.eyebrow}</span>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
              {section.bullets && (
                <ul class="fp-bullets">
                  {section.bullets.map((b) => (
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      {b}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <div class="fp-shot reveal">
              <ScreenshotShot
                id={`fp-${slug}-s${i}`}
                src={section.screenshot.src}
                srcDark={section.screenshot.srcDark}
                alt={section.screenshot.alt}
              />
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- gallery -->
    {gallery && gallery.length > 0 && (
      <section class="band">
        <div class="wrap">
          <div class="sec-head reveal" style="text-align:center">
            <span class="eyebrow">Gallery</span>
            <h2>More of {eyebrow} in action</h2>
          </div>
          <div class="fp-gallery">
            {gallery.map((g, i) => (
              <figure class="fp-gallery-item reveal">
                <ScreenshotShot id={`fp-${slug}-g${i}`} src={g.src} srcDark={g.srcDark} alt={g.alt} />
                <figcaption>{g.caption}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- capability grid -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head reveal" style="text-align:center">
          <span class="eyebrow">Capabilities</span>
          <h2>Everything in the box</h2>
        </div>
        <div class="fp-caps">
          {capabilities.map((c) => (
            <div class="fp-cap reveal">
              <h4>{c.title}</h4>
              <p>{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="band">
      <div class="wrap fp-faq-wrap">
        <div class="sec-head reveal" style="text-align:center">
          <span class="eyebrow">FAQ</span>
          <h2>Common questions</h2>
        </div>
        <div class="fp-faq reveal">
          {faq.map((f) => (
            <details class="fp-faq-item">
              <summary>
                {f.q}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- related features -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head reveal" style="text-align:center">
          <span class="eyebrow">Keep exploring</span>
          <h2>More chmonitor features</h2>
        </div>
        <div class="fp-related">
          {relatedPages.map((r) => (
            <a class="fp-related-card reveal" href={`/features/${r.slug}`}>
              <span class="eyebrow">{r.eyebrow}</span>
              <h4>{r.h1}</h4>
              <p>{r.subhead}</p>
              <span class="fp-related-more">
                Learn more
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <FinalCta />
  </main>
  <Footer />

  <style>
    /* Promoted page title: same scale convention as pricing/changelog. */
    .fp-h1{font-size:clamp(30px,4vw,48px);line-height:1.08;letter-spacing:-.028em;font-weight:700;margin-top:14px;text-wrap:balance}
    .fp-hero{padding-bottom:0}
    .fp-hero .sec-head p{margin-top:14px;max-width:640px;margin-inline:auto}
    .fp-hero-shot{margin-top:44px;border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);overflow:hidden;background:var(--card)}

    /* stat strip — shadcn-card look with hairline dividers */
    .fp-stats-band{padding-top:34px;padding-bottom:34px}
    .fp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);background:var(--card);overflow:hidden}
    .fp-stat{display:flex;flex-direction:column;gap:6px;padding:22px 24px;border-left:1px solid var(--border)}
    .fp-stat:first-child{border-left:none}
    .fp-stat strong{font-size:24px;font-weight:700;letter-spacing:-.02em}
    .fp-stat span{font-size:13.5px;color:var(--muted-fg);line-height:1.45}

    /* deep-dive sections */
    .fp-section{display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);gap:clamp(28px,4.5vw,64px);align-items:center}
    .fp-section.fp-reverse .fp-copy{order:2}
    .fp-section.fp-reverse .fp-shot{order:1}
    .fp-copy h2{font-size:clamp(24px,2.8vw,34px);line-height:1.14;letter-spacing:-.024em;font-weight:700;margin-top:12px}
    .fp-copy > p{margin-top:12px;color:var(--muted-fg);line-height:1.65}
    .fp-bullets{margin-top:18px;display:flex;flex-direction:column;gap:10px}
    .fp-bullets li{display:flex;gap:10px;align-items:flex-start;font-size:14.5px;line-height:1.5;color:var(--fg-soft)}
    .fp-bullets svg{width:16px;height:16px;flex:0 0 auto;margin-top:2px;color:var(--semantic-success)}
    .fp-shot{border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);overflow:hidden;background:var(--card)}

    /* gallery */
    .fp-gallery{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:22px}
    .fp-gallery-item{margin:0;border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);overflow:hidden;background:var(--card)}
    .fp-gallery-item figcaption{padding:12px 16px;font-size:13.5px;color:var(--muted-fg);border-top:1px solid var(--border-soft, var(--border))}

    /* capability grid — quiet shadcn cards */
    .fp-caps{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .fp-cap{border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);background:var(--card);padding:20px 22px}
    .fp-cap h4{font-size:15px;font-weight:600;letter-spacing:-.01em}
    .fp-cap p{margin-top:6px;font-size:13.5px;line-height:1.55;color:var(--muted-fg)}

    /* FAQ — native details/summary, accordion look */
    .fp-faq-wrap{max-width:760px}
    .fp-faq{display:flex;flex-direction:column;gap:10px}
    .fp-faq-item{border:1px solid var(--border);border-radius:var(--radius);background:var(--card);padding:0 18px}
    .fp-faq-item summary{display:flex;align-items:center;justify-content:space-between;gap:14px;cursor:pointer;
      list-style:none;padding:16px 0;font-size:15px;font-weight:600;letter-spacing:-.01em}
    .fp-faq-item summary::-webkit-details-marker{display:none}
    .fp-faq-item summary svg{width:16px;height:16px;flex:0 0 auto;color:var(--muted-fg);transition:transform .2s ease}
    .fp-faq-item[open] summary svg{transform:rotate(180deg)}
    .fp-faq-item > p{padding:0 0 16px;font-size:14.5px;line-height:1.65;color:var(--muted-fg)}

    /* related cards */
    .fp-related{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .fp-related-card{display:flex;flex-direction:column;gap:8px;border:1px solid var(--border);
      border-radius:calc(var(--radius) + 4px);background:var(--card);padding:22px;transition:border-color .15s,background .15s}
    .fp-related-card:hover{border-color:var(--border-hover, var(--hairline-strong));background:var(--muted)}
    .fp-related-card h4{font-size:16px;font-weight:600;letter-spacing:-.015em}
    .fp-related-card p{font-size:13.5px;line-height:1.55;color:var(--muted-fg);
      display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .fp-related-more{display:inline-flex;align-items:center;gap:6px;margin-top:auto;padding-top:8px;
      font-size:13.5px;font-weight:500;color:var(--fg-soft)}
    .fp-related-more svg{width:14px;height:14px;transition:transform .15s}
    .fp-related-card:hover .fp-related-more svg{transform:translateX(3px)}

    @media (max-width: 900px){
      .fp-stats{grid-template-columns:repeat(2,1fr)}
      .fp-stat{border-left:none;border-top:1px solid var(--border)}
      .fp-stat:nth-child(-n+2){border-top:none}
      .fp-stat:nth-child(even){border-left:1px solid var(--border)}
      .fp-section{grid-template-columns:1fr;gap:26px}
      .fp-section.fp-reverse .fp-copy{order:1}
      .fp-section.fp-reverse .fp-shot{order:2}
      .fp-caps,.fp-related{grid-template-columns:1fr 1fr}
    }
    @media (max-width: 640px){
      .fp-gallery,.fp-caps,.fp-related{grid-template-columns:1fr}
    }
  </style>
</Base>
